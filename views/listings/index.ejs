<% layout("/layouts/boilerplate.ejs")%>
  <!--filters options-->
  <div id="filters">
    <a href="/listings?category=Trending" class="icons">
      <div class="filter">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
    </a>

  </div>
  <a href="/listings?category=Trending" class="icons">
    <div class="filter">

      <div><i class="fa-solid fa-bed"></i></div>
      <p>Rooms</p>

    </div>
  </a>

  <a href="/listings?category=Cities" class="icons">
    <div class="filter">
      <div><i class="fa-solid fa-mountain-city"></i></i></div>
      <p>Iconic Cities</p>
    </div>
  </a>
  <a href="/listings?category=Mountains" class="icons">
    <div class="filter">
      <i class="fa-solid fa-mountain"></i>
      <p>Mountains</p>
    </div>
  </a>
  <a href="/listings?category=Pools" class="icons">
    <div class="filter">

      <i class="fa-solid fa-person-swimming"></i>
      <p>Amazing Pools</p>
    </div>
  </a>

  <a href="/listings?category=Beach" class="icons">
    <div class="filter">
      <div> <i class="fa-solid fa-umbrella-beach"></i></div>
      <p>Beach</p>
    </div>
  </a>

  <div class="filter">
    <a href="/listings?category=Camping" class="icons">
      <div> <i class="fa-solid fa-campground"></i></div>
      <p>Camping</p>
    </a>
  </div>
  <div class="filter">
    <a href="/listings?category=Dome" class="icons">
      <div><i class="fa-solid fa-landmark-dome"></i></div>
      <p>Dome</p>
    </a>
  </div>
  <div class="filter">
    <a href="/listings?category=Boats" class="icons">
      <div> <i class="fa-solid fa-sailboat"></i></div>
      <p>Boats</p>
    </a>
  </div>
  <a href="/listings?category=Snow" class="icons">
    <div class="filter">
      <div> <i class="fa-solid fa-igloo"></i></div>
      <p>Arctic</p>
    </div>
  </a>

  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>

  </div>
  </div>

  <!--All listings -->
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1">
    <% for(let listing of allListings){%>
      <a href="/listings/<%=listing._id%>" class="listing-link">
        <div class="card col listing-card">
          <img src="<%= listing.image.url %>" class="card-img-top" style="height:20rem">
          <div class="card-img-overlay">
          </div>
          <div class="card-body">

            <div> <b>
                <%= listing.title %>
              </b></div>

            &#8377; <%= listing.price %>/night
              <i class="tax-info"> &nbsp; &nbsp; +18% GST</i>
          </div>
        </div>
      </a>
      <%}%>
  </div>